# Copy these into Railway → your service → Variables
# Replace placeholders with your real values

APP_NAME="Prompt Edit"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate--show
APP_DEBUG=false
# Must use https:// (not http://) or assets load as mixed content
APP_URL=https://your-custom-domain.com
ASSET_URL=https://your-custom-domain.com

LOG_CHANNEL=stderr
LOG_LEVEL=error

# File-based drivers work without PostgreSQL (recommended for sales page only)
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Only if you added Railway PostgreSQL and ran migrations:
# DB_CONNECTION=pgsql
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# SESSION_DRIVER=database
# CACHE_STORE=database
# QUEUE_CONNECTION=database

SALES_CTA_URL=#pricing
VITE_APP_NAME="${APP_NAME}"
